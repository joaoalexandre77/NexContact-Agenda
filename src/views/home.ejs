<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Document</title>
</head>
<body>
    <div class="container">
            <div class="card">
                <div class="card-header">
                    <h1>Cadastrar cliente</h1>
                    <a href="/sair"><button class="btn btn-danger">Sair</button></a>
                </div>
                <div class="card-body">
                    <form action="/clientes/cadastrar" method="POST">
                        <label>Nome cliente</label>
                        <input type="text" name="nome" placeholder="Insira o nome do cliente" class="form-control" required>

                        <label>CPF cliente</label>
                        <input type="text" name="cpf" placeholder="Insira o cpf do cliente" class="form-control" required>

                        <label>Endereço cliente</label>
                        <input type="text" name="endereco" placeholder="Insira o endereço do cliente" class="form-control" required>

                        <button type="submit" class="btn btn-success">Cadastrar</button>
                        <button type="reset" class="btn btn-danger">Limpar</button>
                    </form>
                    <hr>
                </div>
            </div>
        </div>

        <div class="container">
            <div class="card">
                <div class="card-header">
                    <h1>Clientes</h1>
                </div>
                <div class="card-body">
                    <table>
                        <thead>
                            <tr>
                                <th></th>
                                <th>Nome:</th>
                                <th>CPF:</th>
                                <th>Endereço:</th>
                                <th colspan="2" style="text-align: center;">Ações:</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

</body>
</html>